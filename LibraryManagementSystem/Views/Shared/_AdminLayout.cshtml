<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Dashboard</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <style>
        body {
            margin: 0;
            background-color: #f4f8f4;
            font-family: 'Segoe UI', sans-serif;
        }

        /* Sidebar */
        .sidebar {
            width: 250px;
            height: 100vh;
            position: fixed;
            background: #7a9e7e; /* sage green */
            padding-top: 30px;
            color: white;
        }

            .sidebar h4 {
                text-align: center;
                margin-bottom: 30px;
                font-weight: 600;
            }

            .sidebar a {
                display: block;
                padding: 12px 25px;
                color: #f1f1f1;
                text-decoration: none;
                font-weight: 500;
                transition: all 0.3s ease;
            }

                .sidebar a:hover {
                    background-color: #5f8762;
                    padding-left: 35px;
                }

                .sidebar a.active {
                    background-color: #4f6f52;
                }

        /* Main content */
        .content {
            margin-left: 250px;
            padding: 40px;
        }

        .logout-link {
            position: absolute;
            bottom: 30px;
            width: 100%;
        }

            .logout-link a {
                color: #ffe5e5;
            }

                .logout-link a:hover {
                    background-color: #a94442;
                }
    </style>
</head>
<body>

    <div class="sidebar">
        <h4>Library Admin</h4>

        <a asp-controller="Admin" asp-action="Index">Dashboard</a>
        <a asp-controller="Admin" asp-action="ManageBooks">Manage Books</a>
        <a asp-controller="Admin" asp-action="BorrowRequests">Borrow Requests</a>
        <a asp-controller="Admin" asp-action="ManageRooms">Manage Rooms</a>
        <a asp-controller="Admin" asp-action="RoomRequests">Room Requests</a>
        <a asp-controller="Admin" asp-action="ReviewFeedback">Review Feedback</a>

        <div class="logout-link text-center">
            <a asp-controller="Admin" asp-action="Logout">Logout</a>
        </div>
    </div>


@* 
    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - Everleaf - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer> *@

    <div class="content">
        @RenderBody()
    </div>

</body>
</html>