@model LibraryManagementSystem.Models.Book

@{
    ViewData["Title"] = "Create Book";
    Layout = "_AdminLayout";
}

<h2>Add New Book</h2>

<form asp-action="CreateBook" method="post">
    <div class="mb-3">
        <label class="form-label">Title</label>
        <input asp-for="Title" class="form-control" />
    </div>

    <div class="mb-3">
        <label class="form-label">Author</label>
        <input asp-for="Author" class="form-control" />
    </div>


    <div class="mb-3">
    <label asp-for="Genre" class="form-label"></label>
    <input asp-for="Genre" class="form-control" />
</div>

<div class="mb-3">
    <label asp-for="Description" class="form-label"></label>
    <textarea asp-for="Description" class="form-control" rows="3"></textarea>
</div> 

  @*   <div class="mb-3">
        <label class="form-label">ISBN</label>
        <input asp-for="Isbn" class="form-control" />
    </div> *@

    <div class="mb-3">
        <label class="form-label">Total Copies</label>
        <input asp-for="TotalCopies" class="form-control" />
    </div>

    <div class="mb-3">
        <label class="form-label">Available Copies</label>
        <input asp-for="CopiesAvailable" class="form-control" />
    </div>

    <button type="submit" class="btn btn-success">Save</button>
</form>
