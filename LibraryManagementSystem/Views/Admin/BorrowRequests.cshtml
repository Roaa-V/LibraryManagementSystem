@model IEnumerable<LibraryManagementSystem.Models.BorrowedBook>

@{
    Layout = "_AdminLayout";
}

<div class="d-flex justify-content-end mb-3">
    <a asp-action="@(ViewData["ExportAction"] ?? "Export")" class="btn"
       style="background-color: #a3d2ca; color: #0b3d2e; font-weight: 500;">
        <i class="bi bi-file-earmark-arrow-down me-1"></i> Export
    </a>
</div>

<div class="container mt-3">
    <h2>Pending Borrow Requests</h2>

    <table class="table table-bordered">
        <thead class="table-dark">
            <tr>
                <th>Student</th>
                <th>Book</th>
                <th>Borrow Date</th>
                <th>Due Date</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var request in Model)
            {
                <tr>
                    <td>@request.Student.Name</td>
                    <td>@request.Book.Title</td>
                    <td>@request.BorrowDate</td>
                    <td>@request.DueDate</td>
                    <td>
                        <a asp-action="ApproveRequest" asp-route-id="@request.Id" class="btn btn-success btn-sm">Approve</a>
                        <a asp-action="RejectRequest" asp-route-id="@request.Id" class="btn btn-danger btn-sm">Reject</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
