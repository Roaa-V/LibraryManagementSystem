@{
    Layout = "_AdminLayout";

    ViewData["Title"] = "Manage Rooms";
}
@model List<LibraryManagementSystem.Models.MeetingRoom>

<div class="container mt-5">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Manage Study Rooms</h2>
        <button class="btn btn-primary">
            + Add New Room
        </button>
    </div>

    <div class="card shadow">
        <div class="card-body">

            <form method="get" asp-action="ExportReports" class="me-2">
                <input type="hidden" name="type" value="reservations" />
                <button type="submit" class="btn"
                        style="background-color: #a3d2ca; color: #0b3d2e; font-weight: 500; border-radius: 10px;">
                    <i class="bi bi-file-earmark-arrow-down me-1"></i> Export Rooms CSV
                </button>
            </form>

            <table class="table table-striped">
                <thead class="table-dark">
                    <tr>
                        <th>Room Name</th>
                        <th>Capacity</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var room in Model)
                    {
                        <tr>
                            <td>@room.RoomName</td>
                            <td>@room.Capacity</td>
                            <td>
                                <span class="badge bg-success">Available</span>
                            </td>
                            <td>
                                <button class="btn btn-sm btn-warning">Edit</button>
                                <button class="btn btn-sm btn-danger">Delete</button>
                            </td>
                        </tr>
                    }
                </tbody>

            </table>

        </div>
    </div>

</div>
