@{
    ViewData["Title"] = "Everleaf - Home";
}

<!-- AOS CSS -->
<link href="https://cdn.jsdelivr.net/npm/aos@2.3.4/dist/aos.css" rel="stylesheet">

<style>
    body {
        font-family: 'Segoe UI', sans-serif;
        background-color: #f4f8f4;
        color: #34495e;
    }

    h1, h2, h3, h4, h5 {
        font-weight: 700;
        color: #2c3e50;
    }

    p {
        color: #555;
    }

    a {
        transition: all 0.3s ease;
    }

    a:hover {
        text-decoration: none;
    }

    /* Hero Section with parallax */
    .hero {
        position: relative;
        background: url('/images/library-hero.jpeg') center/cover no-repeat fixed;
        background-size: cover; /* makes it fill entire section */
        min-height: 90vh; /* ensures it’s tall enough */
        width: 100%; /* full width */
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .hero {
        background-attachment: scroll; /* instead of fixed */
    }
    .hero .overlay {
        position: absolute;
        top: 0;
        left: 0;
        height: 100%;
        width: 100%;
        background-color: rgba(0,0,0,0.45);
    }

    .hero .container {
        position: relative;
        z-index: 2;
    }

    .hero h1 {
        font-size: 3rem;
        margin-bottom: 20px;
        text-shadow: 2px 2px 10px rgba(0,0,0,0.5);
    }

    .hero p {
        font-size: 1.25rem;
        text-shadow: 1px 1px 6px rgba(0,0,0,0.3);
    }

    .hero .btn-browse {
        background-color: #7a9e7e;
        border-color: #5f8762;
        color: #fff;
    }

    .hero .btn-browse:hover {
        background-color: #5f8762;
    }

    .hero .btn-outline-light {
        border-color: #e6c3c3;
        color: #e6c3c3;
    }

    .hero .btn-outline-light:hover {
        background-color: #e6c3c3;
        color: #2c3e50;
    }

    section {
        padding: 80px 0;
    }

    .section-bg {
        background-color: #f5e9e0;
    }

    /* Feature cards with buttons */
    .features .card {
        border-radius: 16px;
        transition: transform 0.3s, box-shadow 0.3s;
        background: #fdf6f0;
    }

    .features .card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.15);
    }

    .features .btn {
        background-color: #d9a066;
        border: none;
        color: #fff;
        margin-top: 10px;
    }

    .features .btn:hover {
        background-color: #c1854a;
    }

    /* Text cards for vision/offers */
    .cards-row .card {
        border-radius: 16px;
        transition: transform 0.3s, box-shadow 0.3s;
        background: #ffffffcc;
    }

    .cards-row .card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.15);
    }

    .cards-row .card h5 {
        color: #7a9e7e;
    }

    .cards-row .card p {
        color: #555;
    }
</style>

<!-- Hero Section -->
<section class="hero d-flex align-items-center justify-content-center text-center" data-aos="fade-in">
    <div class="overlay"></div>
    <div class="container position-relative" data-aos="zoom-in" data-aos-delay="200">
        <h1 class="display-4 fw-bold text-white">Welcome to Everleaf</h1>
        <p class="lead text-white-50 mb-4">Discover, reserve, and explore – your library experience reimagined.</p>
        <a asp-controller="Student" asp-action="BookSearch" class="btn btn-browse btn-lg me-2">Browse Books</a>
        <a asp-controller="Account" asp-action="LoginChoice" class="btn btn-outline-light btn-lg">Login</a>
    </div>
</section>

<!-- Features Section with buttons -->
<section class="features py-5 bg-white" data-aos="fade-up">
    <div class="container">
        <div class="row text-center">
            <div class="col-md-4 mb-4" data-aos="fade-up" data-aos-delay="100">
                <div class="card shadow-sm h-100">
                    <div class="card-body">
                        <h5 class="card-title">Explore Books</h5>
                        <p class="card-text">Find your favorite books quickly with our powerful search.</p>

                        <a asp-controller="Student" asp-action="BookSearch" class="btn">Browse</a>
                    </div>
                </div>
            </div>
            <div class="col-md-4 mb-4" data-aos="fade-up" data-aos-delay="200">
                <div class="card shadow-sm h-100">
                    <div class="card-body">
                        <h5 class="card-title">Reserve Rooms</h5>
                        <p class="card-text">Book a study or meeting room with a few clicks.</p>
                        <a asp-controller="Student" asp-action="RoomReservation" class="btn">Reserve</a>
                    </div>
                </div>
            </div>
            <div class="col-md-4 mb-4" data-aos="fade-up" data-aos-delay="300">
                <div class="card shadow-sm h-100">
                    <div class="card-body">
                        <h5 class="card-title">Give Feedback</h5>
                        <p class="card-text">Share your thoughts to help us improve the library experience.</p>
                        <a asp-controller="Student" asp-action="Feedback" class="btn">Give Feedback</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- About Us -->
<section class="about py-5" style="background: url('/images/1.jpeg') center center / cover no-repeat;">
    <div class="container">
        <h2 class="text-center mb-5" data-aos="fade-right">About Everleaf</h2>
        <p class="text-center mx-auto"
        <p class="text-center mx-auto"
           style="max-width:800px; color:#001f54;"
           data-aos="fade-left">
            Everleaf is more than a library; it's a space where knowledge, creativity, and community come together.
            Explore books, reserve rooms, and participate in events – all in a cozy, modern environment.
        </p>
    </div>
</section>

<!-- AOS JS -->
<script src="https://cdn.jsdelivr.net/npm/aos@2.3.4/dist/aos.js"></script>
<script>
    AOS.init({
        duration: 1000,
        easing: 'ease-in-out',
        once: true,
        mirror: false
    });
</script>